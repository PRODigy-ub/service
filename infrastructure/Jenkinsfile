pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    tools {
        jdk 'jdk21'
        gradle 'gradle-8'
    }

    environment {
        DOCKER_PASSWORD = credentials('docker_password')
        GITHUB_TOKEN = credentials('github_token')
        IMAGE_NAME = 'prod-eng-img'
    }

    stages {
        stage('Build') {
            steps {
                sh './gradlew clean build'
            }
        }

        stage('Test') {
            steps {
                sh './gradlew test'
            }
        }

        stage('Version & Tag') {
            steps {
                script {
                    sh 'git fetch --tags --force'

                    def latestTag = sh(
                        script: "git tag | grep -E '^[0-9]+\\.[0-9]+\\.[0-9]+$' | sort -V | tail -1 || true",
                        returnStdout: true
                    ).trim()

                    def major = 0
                    def minor = 0
                    def patch = 0

                    if (latestTag) {
                        def parts = latestTag.tokenize('.')
                        major = parts[0].toInteger()
                        minor = parts[1].toInteger()
                        patch = parts[2].toInteger()
                    }

                    env.IMAGE_TAG = "${major}.${minor + 1}.${patch}"
                    echo "Latest release tag: ${latestTag ?: 'none'}"
                    echo "Building version: ${env.IMAGE_TAG}"
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t $DOCKER_PASSWORD_USR/$IMAGE_NAME:$IMAGE_TAG -f Dockerfile .'
            }
        }

        stage('Push to Docker Hub') {
            steps {
                sh '''
                    echo $DOCKER_PASSWORD_PSW | docker login docker.io -u $DOCKER_PASSWORD_USR --password-stdin
                    docker push $DOCKER_PASSWORD_USR/$IMAGE_NAME:$IMAGE_TAG
                '''
            }
        }

        stage('Tag Release') {
            steps {
                sh '''
                    set -e
                    git config user.email "jenkins@local"
                    git config user.name "Jenkins"
                    git fetch --tags --force

                    if git show-ref --tags --verify --quiet refs/tags/$IMAGE_TAG; then
                        echo "Tag $IMAGE_TAG already exists. Skipping creation."
                    else
                        git tag $IMAGE_TAG
                    fi

                    ORIGIN_URL=$(git remote get-url origin)
                    if echo "$ORIGIN_URL" | grep -q '^git@github.com:'; then
                        ORIGIN_URL=$(echo "$ORIGIN_URL" | sed 's#git@github.com:#https://github.com/#')
                    fi
                    AUTH_URL=$(echo "$ORIGIN_URL" | sed "s#https://#https://$GITHUB_TOKEN_USR:$GITHUB_TOKEN_PSW@#")

                    git push "$AUTH_URL" $IMAGE_TAG
                '''
            }
        }
    }

    post {
        always {
            sh 'docker logout docker.io || true'
        }
    }
}
